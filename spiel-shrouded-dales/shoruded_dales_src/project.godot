; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Sd"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.1", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://subsystems/audiomanager/default_bus_layout.tres"

[autoload]

SignalManager="*res://subsystems/signalmanager/signalmanager.gd"
PlayerManager="*res://subsystems/combatmanager/combatmanager.gd"

[display]

window/size/viewport_width=854
window/size/viewport_height=480
window/stretch/mode="canvas_items"

[gui]

theme/custom="res://scenes/ui/hud/styles/default_theme.tres"

